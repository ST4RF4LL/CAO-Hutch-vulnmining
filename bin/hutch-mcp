#!/usr/bin/env python3
"""Run Hutch MCP with the FastMCP dependency from the local CAO environment."""

from __future__ import annotations

import os
import shutil
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
CAO_REPO = Path(
    os.environ.get(
        "CAO_REPO", "/Users/wh4lter/Workspace/lab/cli-agent-orchestrator"
    )
).expanduser().resolve()
uv = shutil.which("uv")
if not uv:
    raise SystemExit("hutch-mcp: uv is not installed")
if not (CAO_REPO / "pyproject.toml").is_file():
    raise SystemExit(f"hutch-mcp: CAO_REPO is not a Python project: {CAO_REPO}")
os.execv(
    uv,
    [
        uv,
        "run",
        "--directory",
        str(CAO_REPO),
        "python",
        "-u",
        str(ROOT / "scripts" / "hutch_mcp_server.py"),
    ],
)
