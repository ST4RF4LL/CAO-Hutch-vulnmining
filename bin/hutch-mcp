#!/usr/bin/env python3
"""Run Hutch MCP with the FastMCP dependency from the local CAO environment."""

from __future__ import annotations

import os
import shutil
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "scripts"))
from hutch_paths import default_cao_repo  # noqa: E402

try:
    CAO_REPO = default_cao_repo()
except RuntimeError as error:
    raise SystemExit(f"hutch-mcp: {error}") from error
uv = shutil.which("uv")
if not uv:
    raise SystemExit("hutch-mcp: uv is not installed")
if not (CAO_REPO / "pyproject.toml").is_file():
    raise SystemExit(f"hutch-mcp: CAO_REPO is not a Python project: {CAO_REPO}")
os.execv(
    uv,
    [
        uv,
        "run",
        "--directory",
        str(CAO_REPO),
        "python",
        "-u",
        str(ROOT / "scripts" / "hutch_mcp_server.py"),
    ],
)
