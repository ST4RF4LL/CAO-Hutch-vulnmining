{
  "schema": "hutch.cao-workflow-template.v1",
  "id": "one-run",
  "version": "1.0.0",
  "name_suffix": "one-run",
  "description": "Single CAO flow combining repository reconnaissance, threat modeling, audit planning, dimension-based vulnerability mining, validation, and reporting.",
  "workflow": {
    "description": "One-run audit for a target project: collect repository intelligence, model threats, plan complete coverage, audit security dimensions, validate findings, and produce a final report.",
    "schedule": "0 0 1 1 *",
    "provider": "opencode_cli",
    "execution": {
      "stage_timeout_seconds": 1800,
      "max_attempts": 2,
      "max_concurrency": 3,
      "register_enabled": false
    },
    "agents": [
      {
        "id": "repository-analyst",
        "store": "agents_store/repository-analyst"
      },
      {
        "id": "threat-modeler",
        "store": "agents_store/threat-modeler"
      },
      {
        "id": "audit-planner",
        "store": "agents_store/audit-planner"
      },
      {
        "id": "attack-surface-miner",
        "store": "agents_store/attack-surface-miner"
      },
      {
        "id": "implementation-miner",
        "store": "agents_store/implementation-miner"
      },
      {
        "id": "finding-validator",
        "store": "agents_store/finding-validator"
      },
      {
        "id": "report-writer",
        "store": "agents_store/report-writer"
      }
    ],
    "stages": [
      {
        "id": "repository-intelligence",
        "task_id": "O-0001",
        "agent": "repository-analyst",
        "depends_on": [],
        "artifact": "artifacts/one-run/01-architecture.md",
        "required_artifacts": [
          "artifacts/one-run/architecture.json",
          "artifacts/one-run/business-flows.json",
          "artifacts/one-run/external-interfaces.json"
        ],
        "inputs": [
          "shared/source-fingerprint.json",
          "shared/target-project.json",
          "shared/repository-inventory.json",
          "shared/modules.json"
        ],
        "required_sections": [
          "Repository Scale and Module Map",
          "Runtime Architecture",
          "Business Logic and Data Flows",
          "External Interfaces",
          "Security-Relevant Components",
          "Evidence and Limitations"
        ],
        "objective": "Produce complete architecture and business intelligence tied to every deterministic module ID.",
        "json_contracts": [
          {
            "artifact": "artifacts/one-run/architecture.json",
            "schema": "hutch.architecture-intelligence.v1",
            "required_fields": [
              "modules",
              "components"
            ],
            "module_coverage": true,
            "module_field": "modules",
            "inventory": "shared/modules.json"
          },
          {
            "artifact": "artifacts/one-run/business-flows.json",
            "schema": "hutch.business-flows.v1",
            "required_fields": [
              "flows"
            ]
          },
          {
            "artifact": "artifacts/one-run/external-interfaces.json",
            "schema": "hutch.external-interfaces.v1",
            "required_fields": [
              "interfaces"
            ]
          }
        ]
      },
      {
        "id": "threat-intelligence",
        "task_id": "O-0002",
        "agent": "threat-modeler",
        "depends_on": [
          "repository-intelligence"
        ],
        "artifact": "artifacts/one-run/02-threat-model.md",
        "required_artifacts": [
          "artifacts/one-run/attack-surface.json",
          "artifacts/one-run/trust-boundaries.json",
          "artifacts/one-run/threat-model.json"
        ],
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/architecture.json",
          "artifacts/one-run/business-flows.json",
          "artifacts/one-run/external-interfaces.json"
        ],
        "required_sections": [
          "Scope Assets and Adversaries",
          "Attack Surface",
          "Trust Boundaries",
          "Threat Scenarios",
          "Expected Security Controls",
          "Audit Intelligence by Module",
          "Evidence and Limitations"
        ],
        "objective": "Produce complete threat intelligence for the one-run mining stages.",
        "json_contracts": [
          {
            "artifact": "artifacts/one-run/attack-surface.json",
            "schema": "hutch.attack-surface.v1",
            "required_fields": [
              "surfaces"
            ]
          },
          {
            "artifact": "artifacts/one-run/trust-boundaries.json",
            "schema": "hutch.trust-boundaries.v1",
            "required_fields": [
              "boundaries"
            ]
          },
          {
            "artifact": "artifacts/one-run/threat-model.json",
            "schema": "hutch.threat-model.v1",
            "required_fields": [
              "threats"
            ]
          }
        ]
      },
      {
        "id": "audit-planning",
        "task_id": "O-0003",
        "agent": "audit-planner",
        "depends_on": [
          "threat-intelligence"
        ],
        "artifact": "artifacts/one-run/03-audit-plan.md",
        "required_artifacts": [
          "artifacts/one-run/audit-plan.json"
        ],
        "inputs": [
          "shared/repository-inventory.json",
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/architecture.json",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/attack-surface.json",
          "artifacts/one-run/trust-boundaries.json",
          "artifacts/one-run/threat-model.json"
        ],
        "required_sections": [
          "Planning Basis",
          "Security Dimensions",
          "Strategy and Concurrency",
          "Module and Path Assignments",
          "Coverage Matrix",
          "Risks and Limitations"
        ],
        "objective": "Produce a machine-valid plan covering every module across attack-surface and implementation-boundary security dimensions.",
        "json_contracts": [
          {
            "artifact": "artifacts/one-run/audit-plan.json",
            "schema": "hutch.audit-plan.v1"
          }
        ],
        "audit_plan_contract": {
          "inventory": "shared/modules.json",
          "artifact": "artifacts/one-run/audit-plan.json"
        }
      },
      {
        "id": "attack-surface-mining",
        "task_id": "O-0004",
        "agent": "attack-surface-miner",
        "depends_on": [
          "audit-planning"
        ],
        "artifact": "artifacts/one-run/04-attack-surface-mining.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/attack-surface.json",
          "artifacts/one-run/threat-model.json",
          "artifacts/one-run/03-audit-plan.md",
          "artifacts/one-run/audit-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage Matrix",
          "Candidate Findings",
          "Reviewed Hotspots and Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Mine externally reachable and attacker-controlled flows for source-proven vulnerability candidates."
      },
      {
        "id": "implementation-mining",
        "task_id": "O-0005",
        "agent": "implementation-miner",
        "depends_on": [
          "audit-planning"
        ],
        "artifact": "artifacts/one-run/05-implementation-mining.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/trust-boundaries.json",
          "artifacts/one-run/threat-model.json",
          "artifacts/one-run/03-audit-plan.md",
          "artifacts/one-run/audit-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage Matrix",
          "Candidate Findings",
          "Reviewed Hotspots and Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Mine implementation-level and runtime-boundary vulnerability candidates with source evidence."
      },
      {
        "id": "finding-validation",
        "task_id": "O-0006",
        "agent": "finding-validator",
        "depends_on": [
          "attack-surface-mining",
          "implementation-mining"
        ],
        "artifact": "artifacts/one-run/06-validation.md",
        "inputs": [
          "outbox/O-0004.result.json",
          "outbox/O-0005.result.json",
          "artifacts/one-run/04-attack-surface-mining.md",
          "artifacts/one-run/05-implementation-mining.md"
        ],
        "required_sections": [
          "Validation Method",
          "Candidate Disposition",
          "Validated Findings",
          "Rejected Candidates",
          "Needs More Information",
          "Deduplication and Attack Chains",
          "Evidence and Limitations"
        ],
        "objective": "Independently validate, classify, and deduplicate every candidate from the mining tracks."
      },
      {
        "id": "final-report",
        "task_id": "O-0007",
        "agent": "report-writer",
        "depends_on": [
          "finding-validation"
        ],
        "artifact": "artifacts/one-run/07-final-report.md",
        "inputs": [
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/03-audit-plan.md",
          "artifacts/one-run/04-attack-surface-mining.md",
          "artifacts/one-run/05-implementation-mining.md",
          "artifacts/one-run/06-validation.md",
          "outbox/O-0006.result.json"
        ],
        "required_sections": [
          "Executive Summary",
          "Scope and Constraints",
          "Architecture and Attack Surface",
          "Coverage Matrix",
          "Validated Findings",
          "Attack Chains",
          "Rejected Candidates and Leads",
          "Remediation Priorities",
          "Evidence and Limitations"
        ],
        "objective": "Produce the complete first-contact vulnerability-mining report from validated evidence."
      }
    ]
  }
}
