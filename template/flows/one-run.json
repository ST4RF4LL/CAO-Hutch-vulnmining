{
  "schema": "hutch.cao-workflow-template.v1",
  "id": "one-run",
  "version": "1.0.0",
  "name_suffix": "one-run",
  "description": "First-contact baseline flow combining information collection, threat modeling, vulnerability mining, validation, and reporting.",
  "workflow": {
    "description": "One-run first-contact baseline for a Git checkout: collect repository intelligence, model threats, mine vulnerabilities, validate findings, and produce a final report.",
    "schedule": "0 0 1 1 *",
    "provider": "opencode_cli",
    "snapshot": {
      "max_file_bytes": 2097152,
      "analysis": "structural"
    },
    "execution": {
      "stage_timeout_seconds": 1800,
      "max_attempts": 2,
      "max_concurrency": 3,
      "register_enabled": false
    },
    "agents": [
      {
        "id": "repository-analyst",
        "description": "Maps repository modules, runtime components, business flows, and external interfaces.",
        "mission": "Use the deterministic module inventory as the completeness boundary. Build architecture, component, business-flow, and external-interface intelligence for every module with source paths and symbols. Do not silently prioritize away low-risk modules and do not claim vulnerabilities.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "audit-skills"
        ]
      },
      {
        "id": "threat-modeler",
        "description": "Builds attack-surface, trust-boundary, and threat intelligence.",
        "mission": "Derive attacker-controlled sources, assets, trust crossings, dangerous sinks, security controls, abuse cases, and threat hypotheses from complete architecture intelligence. Preserve module IDs and distinguish source evidence, inference, and missing deployment facts.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management"
        ]
      },
      {
        "id": "attack-surface-miner",
        "description": "Mines externally reachable and attacker-controlled flows.",
        "mission": "Audit externally reachable entry points and attacker-controlled data flows for injection, SSRF, deserialization, file/path/archive abuse, command execution, unsafe redirects, authentication, authorization, and security-control bypass. Prove source-to-sink reachability before reporting candidates.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "java-injection-review",
          "java-web-security-review",
          "java-deserialization-review",
          "audit-skills"
        ]
      },
      {
        "id": "implementation-miner",
        "description": "Mines implementation-level flaws across language and runtime boundaries.",
        "mission": "Audit parser, serialization, native/FFI, reflection, dynamic loading, concurrency, state-machine, cryptographic, temporary-file, path, archive, and memory-safety sensitive implementation paths. Preserve negative results and unchecked paths.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "c-cpp-memory-safety-review",
          "c-cpp-native-boundary-review",
          "c-cpp-file-privilege-review",
          "audit-skills"
        ]
      },
      {
        "id": "component-supplychain-miner",
        "description": "Mines component, dependency, build, release, and configuration trust issues.",
        "mission": "Audit dependency declarations, build plugins, repositories, artifact downloads, dynamic plugins, model or data loading, CI/release scripts, secrets, unsafe defaults, and configuration trust. Separate locally source-proven issues from external verification leads.",
        "atlas": false,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "audit-skills"
        ]
      },
      {
        "id": "finding-validator",
        "description": "Validates and deduplicates every candidate finding.",
        "mission": "Re-read cited source paths, reproduce each static argument, challenge attacker control and reachability, inspect sanitizers and deployment assumptions, deduplicate candidates, and classify each as confirmed, likely, needs-info, or false-positive.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "vulnerability-validation"
        ]
      },
      {
        "id": "report-writer",
        "description": "Produces the final evidence-linked first-contact audit report.",
        "mission": "Synthesize repository intelligence, threat model, validated findings, coverage, attack chains, negative results, limitations, and prioritized remediation. Only confirmed and likely items may appear as report findings; preserve needs-info items as leads and false positives as rejected candidates.",
        "atlas": false,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management"
        ]
      }
    ],
    "stages": [
      {
        "id": "repository-intelligence",
        "task_id": "O-0001",
        "agent": "repository-analyst",
        "depends_on": [],
        "artifact": "artifacts/one-run/01-architecture.md",
        "required_artifacts": [
          "artifacts/one-run/architecture.json",
          "artifacts/one-run/business-flows.json",
          "artifacts/one-run/external-interfaces.json"
        ],
        "inputs": [
          "shared/source-fingerprint.json",
          "shared/snapshot-manifest.json",
          "shared/repository-inventory.json",
          "shared/modules.json"
        ],
        "required_sections": [
          "Repository Scale and Module Map",
          "Runtime Architecture",
          "Business Logic and Data Flows",
          "External Interfaces",
          "Security-Relevant Components",
          "Evidence and Limitations"
        ],
        "objective": "Produce complete architecture and business intelligence tied to every deterministic module ID.",
        "json_contracts": [
          {
            "artifact": "artifacts/one-run/architecture.json",
            "schema": "hutch.architecture-intelligence.v1",
            "required_fields": [
              "modules",
              "components"
            ],
            "module_coverage": true,
            "module_field": "modules",
            "inventory": "shared/modules.json"
          },
          {
            "artifact": "artifacts/one-run/business-flows.json",
            "schema": "hutch.business-flows.v1",
            "required_fields": [
              "flows"
            ]
          },
          {
            "artifact": "artifacts/one-run/external-interfaces.json",
            "schema": "hutch.external-interfaces.v1",
            "required_fields": [
              "interfaces"
            ]
          }
        ]
      },
      {
        "id": "threat-intelligence",
        "task_id": "O-0002",
        "agent": "threat-modeler",
        "depends_on": [
          "repository-intelligence"
        ],
        "artifact": "artifacts/one-run/02-threat-model.md",
        "required_artifacts": [
          "artifacts/one-run/attack-surface.json",
          "artifacts/one-run/trust-boundaries.json",
          "artifacts/one-run/threat-model.json"
        ],
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/architecture.json",
          "artifacts/one-run/business-flows.json",
          "artifacts/one-run/external-interfaces.json"
        ],
        "required_sections": [
          "Scope Assets and Adversaries",
          "Attack Surface",
          "Trust Boundaries",
          "Threat Scenarios",
          "Expected Security Controls",
          "Audit Intelligence by Module",
          "Evidence and Limitations"
        ],
        "objective": "Produce complete threat intelligence for the one-run mining stages.",
        "json_contracts": [
          {
            "artifact": "artifacts/one-run/attack-surface.json",
            "schema": "hutch.attack-surface.v1",
            "required_fields": [
              "surfaces"
            ]
          },
          {
            "artifact": "artifacts/one-run/trust-boundaries.json",
            "schema": "hutch.trust-boundaries.v1",
            "required_fields": [
              "boundaries"
            ]
          },
          {
            "artifact": "artifacts/one-run/threat-model.json",
            "schema": "hutch.threat-model.v1",
            "required_fields": [
              "threats"
            ]
          }
        ]
      },
      {
        "id": "attack-surface-mining",
        "task_id": "O-0003",
        "agent": "attack-surface-miner",
        "depends_on": [
          "threat-intelligence"
        ],
        "artifact": "artifacts/one-run/03-attack-surface-mining.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/attack-surface.json",
          "artifacts/one-run/threat-model.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage Matrix",
          "Candidate Findings",
          "Reviewed Hotspots and Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Mine externally reachable and attacker-controlled flows for source-proven vulnerability candidates."
      },
      {
        "id": "implementation-mining",
        "task_id": "O-0004",
        "agent": "implementation-miner",
        "depends_on": [
          "threat-intelligence"
        ],
        "artifact": "artifacts/one-run/04-implementation-mining.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/trust-boundaries.json",
          "artifacts/one-run/threat-model.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage Matrix",
          "Candidate Findings",
          "Reviewed Hotspots and Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Mine implementation-level and runtime-boundary vulnerability candidates with source evidence."
      },
      {
        "id": "component-supplychain-mining",
        "task_id": "O-0005",
        "agent": "component-supplychain-miner",
        "depends_on": [
          "threat-intelligence"
        ],
        "artifact": "artifacts/one-run/05-component-supplychain-mining.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/external-interfaces.json",
          "artifacts/one-run/threat-model.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Dependency and Build Trust",
          "Artifact and Plugin Trust",
          "Candidate Findings",
          "External Verification Leads",
          "Evidence and Limitations"
        ],
        "objective": "Mine component, dependency, build, release, and configuration trust issues using local evidence."
      },
      {
        "id": "finding-validation",
        "task_id": "O-0006",
        "agent": "finding-validator",
        "depends_on": [
          "attack-surface-mining",
          "implementation-mining",
          "component-supplychain-mining"
        ],
        "artifact": "artifacts/one-run/06-validation.md",
        "inputs": [
          "artifacts/one-run/03-attack-surface-mining.md",
          "artifacts/one-run/04-implementation-mining.md",
          "artifacts/one-run/05-component-supplychain-mining.md",
          "outbox/O-0003.result.json",
          "outbox/O-0004.result.json",
          "outbox/O-0005.result.json"
        ],
        "required_sections": [
          "Validation Method",
          "Candidate Disposition",
          "Validated Findings",
          "Rejected Candidates",
          "Needs More Information",
          "Deduplication and Attack Chains",
          "Evidence and Limitations"
        ],
        "objective": "Independently validate, classify, and deduplicate every candidate from the mining tracks."
      },
      {
        "id": "final-report",
        "task_id": "O-0007",
        "agent": "report-writer",
        "depends_on": [
          "finding-validation"
        ],
        "artifact": "artifacts/one-run/07-final-report.md",
        "inputs": [
          "artifacts/one-run/01-architecture.md",
          "artifacts/one-run/02-threat-model.md",
          "artifacts/one-run/03-attack-surface-mining.md",
          "artifacts/one-run/04-implementation-mining.md",
          "artifacts/one-run/05-component-supplychain-mining.md",
          "artifacts/one-run/06-validation.md",
          "outbox/O-0006.result.json"
        ],
        "required_sections": [
          "Executive Summary",
          "Scope and Constraints",
          "Architecture and Attack Surface",
          "Coverage Matrix",
          "Validated Findings",
          "Attack Chains",
          "Rejected Candidates and Leads",
          "Remediation Priorities",
          "Evidence and Limitations"
        ],
        "objective": "Produce the complete first-contact vulnerability-mining report from validated evidence."
      }
    ]
  }
}
