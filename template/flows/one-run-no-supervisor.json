{
  "schema": "hutch.cao-workflow-template.v1",
  "id": "one-run-no-supervisor",
  "version": "1.0.0",
  "name_suffix": "one-run-direct",
  "description": "CAO-owned end-to-end audit without a dedicated supervisor profile: recon and planning drive conditional language/domain agents and final reporting.",
  "workflow": {
    "description": "Direct CAO workflow for repository recon, evidence-based audit planning, conditional Java/Web/C/Python/Reverse audits, and final reporting.",
    "schedule": "0 0 1 1 *",
    "provider": "opencode_cli",
    "snapshot": {
      "max_file_bytes": 2097152,
      "analysis": "structural"
    },
    "execution": {
      "stage_timeout_seconds": 1800,
      "max_attempts": 2,
      "max_concurrency": 5,
      "register_enabled": false,
      "no_supervisor": true,
      "entry_agent": "recon-planner",
      "entry_stages": [
        "recon",
        "planning"
      ]
    },
    "agents": [
      {
        "id": "recon-planner",
        "description": "Performs repository reconnaissance and decides which domain auditors are relevant.",
        "mission": "First build source-grounded repository, language, framework, interface, trust-boundary, and attack-surface intelligence. Then produce the authoritative domain audit plan. Decide run or skip independently for java, web, c, python, and reverse. Every skip requires concrete repository evidence; uncertainty should select run. After planning, coordinate only the selected CAO workers and the final report.",
        "atlas": true,
        "orchestrates": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management"
        ]
      },
      {
        "id": "java-auditor",
        "description": "Audits Java and JVM security boundaries.",
        "mission": "Audit Java/JVM code for injection, deserialization, authentication and authorization, expression and reflection abuse, file/path operations, SSRF, cryptography, concurrency, and framework-specific security-control gaps. Report only source-grounded candidates.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "java-injection-review",
          "java-web-security-review",
          "java-deserialization-review"
        ]
      },
      {
        "id": "web-auditor",
        "description": "Audits HTTP, API, browser-facing, and authorization attack surfaces.",
        "mission": "Audit routes, controllers, handlers, middleware, authentication, authorization, tenant isolation, request parsing, redirects, uploads, SSRF, injection, session and token handling, and browser-facing trust boundaries across all applicable languages.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "java-web-security-review"
        ]
      },
      {
        "id": "c-auditor",
        "description": "Audits C/C++ native and memory-safety boundaries.",
        "mission": "Audit C/C++ and native boundaries for memory corruption, integer and lifetime errors, unsafe parsing, command and file operations, privilege boundaries, JNI/FFI crossings, concurrency, dynamic loading, and attacker-controlled native inputs.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management",
          "c-cpp-memory-safety-review",
          "c-cpp-native-boundary-review",
          "c-cpp-file-privilege-review"
        ]
      },
      {
        "id": "python-auditor",
        "description": "Audits Python application and automation security boundaries.",
        "mission": "Audit Python code for command, template and query injection, unsafe deserialization, dynamic execution and imports, path and archive handling, SSRF, authentication and authorization, secret handling, subprocess use, and framework-specific control gaps.",
        "atlas": true,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management"
        ]
      },
      {
        "id": "reverse-auditor",
        "description": "Performs static reverse-oriented review of opaque, generated, packaged, or native artifacts.",
        "mission": "Statically inspect repository-contained binaries, bytecode, generated code, protocol definitions, native wrappers, packaged assets, loaders, and undocumented interfaces when present. Correlate opaque behavior back to source and report limitations when artifacts are absent. Never execute target artifacts.",
        "atlas": false,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management"
        ]
      },
      {
        "id": "report-writer",
        "description": "Integrates recon, planning decisions, executed audits, skipped evidence, and findings.",
        "mission": "Produce one evidence-linked final report. Preserve every planning decision, clearly distinguish executed and skipped domains, deduplicate findings, construct attack chains, record negative results and limitations, and never present skipped-domain coverage as audited.",
        "atlas": false,
        "skills": [
          "secure-code-review-common",
          "audit-artifact-management"
        ]
      }
    ],
    "stages": [
      {
        "id": "recon",
        "task_id": "D-0001",
        "agent": "recon-planner",
        "depends_on": [],
        "artifact": "artifacts/direct/01-recon.md",
        "required_artifacts": [
          "artifacts/direct/recon.json"
        ],
        "inputs": [
          "shared/source-fingerprint.json",
          "shared/snapshot-manifest.json",
          "shared/repository-inventory.json",
          "shared/modules.json"
        ],
        "required_sections": [
          "Repository and Module Map",
          "Languages Frameworks and Artifacts",
          "External Interfaces",
          "Business and Data Flows",
          "Trust Boundaries and Attack Surface",
          "Audit Routing Evidence",
          "Limitations"
        ],
        "objective": "Build complete evidence for deciding which specialized audit domains are applicable.",
        "json_contracts": [
          {
            "artifact": "artifacts/direct/recon.json",
            "schema": "hutch.direct-recon.v1",
            "required_fields": [
              "languages",
              "frameworks",
              "interfaces",
              "artifacts",
              "modules",
              "threats"
            ],
            "module_coverage": true,
            "module_field": "modules",
            "inventory": "shared/modules.json"
          }
        ]
      },
      {
        "id": "planning",
        "task_id": "D-0002",
        "agent": "recon-planner",
        "depends_on": [
          "recon"
        ],
        "artifact": "artifacts/direct/02-plan.md",
        "required_artifacts": [
          "artifacts/direct/domain-plan.json"
        ],
        "inputs": [
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json"
        ],
        "required_sections": [
          "Planning Basis",
          "Domain Decisions",
          "Selected Scope and Priorities",
          "Cross-Domain Correlation Plan",
          "Skipped Domains and Evidence",
          "Limitations"
        ],
        "objective": "Decide whether each configured audit domain must run or may be skipped.",
        "json_contracts": [
          {
            "artifact": "artifacts/direct/domain-plan.json",
            "schema": "hutch.domain-audit-plan.v1",
            "required_fields": [
              "decisions"
            ]
          }
        ],
        "domain_plan_contract": {
          "artifact": "artifacts/direct/domain-plan.json",
          "domains": [
            "java",
            "web",
            "c",
            "python",
            "reverse"
          ]
        }
      },
      {
        "id": "java-audit",
        "task_id": "D-0101",
        "agent": "java-auditor",
        "depends_on": [
          "planning"
        ],
        "artifact": "artifacts/direct/domains/java.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json",
          "artifacts/direct/02-plan.md",
          "artifacts/direct/domain-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage",
          "Candidate Findings",
          "Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Perform the planned Java/JVM audit.",
        "domain_condition": {
          "domain": "java",
          "plan_artifact": "artifacts/direct/domain-plan.json"
        }
      },
      {
        "id": "web-audit",
        "task_id": "D-0102",
        "agent": "web-auditor",
        "depends_on": [
          "planning"
        ],
        "artifact": "artifacts/direct/domains/web.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json",
          "artifacts/direct/02-plan.md",
          "artifacts/direct/domain-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage",
          "Candidate Findings",
          "Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Perform the planned Web/API/authentication/authorization audit.",
        "domain_condition": {
          "domain": "web",
          "plan_artifact": "artifacts/direct/domain-plan.json"
        }
      },
      {
        "id": "c-audit",
        "task_id": "D-0103",
        "agent": "c-auditor",
        "depends_on": [
          "planning"
        ],
        "artifact": "artifacts/direct/domains/c.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json",
          "artifacts/direct/02-plan.md",
          "artifacts/direct/domain-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage",
          "Candidate Findings",
          "Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Perform the planned C/C++ native security audit.",
        "domain_condition": {
          "domain": "c",
          "plan_artifact": "artifacts/direct/domain-plan.json"
        }
      },
      {
        "id": "python-audit",
        "task_id": "D-0104",
        "agent": "python-auditor",
        "depends_on": [
          "planning"
        ],
        "artifact": "artifacts/direct/domains/python.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json",
          "artifacts/direct/02-plan.md",
          "artifacts/direct/domain-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage",
          "Candidate Findings",
          "Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Perform the planned Python security audit.",
        "domain_condition": {
          "domain": "python",
          "plan_artifact": "artifacts/direct/domain-plan.json"
        }
      },
      {
        "id": "reverse-audit",
        "task_id": "D-0105",
        "agent": "reverse-auditor",
        "depends_on": [
          "planning"
        ],
        "artifact": "artifacts/direct/domains/reverse.md",
        "inputs": [
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json",
          "artifacts/direct/02-plan.md",
          "artifacts/direct/domain-plan.json"
        ],
        "required_sections": [
          "Scope and Method",
          "Coverage",
          "Candidate Findings",
          "Negative Results",
          "Unchecked Paths",
          "Evidence and Limitations"
        ],
        "objective": "Perform the planned static reverse-oriented audit.",
        "domain_condition": {
          "domain": "reverse",
          "plan_artifact": "artifacts/direct/domain-plan.json"
        }
      },
      {
        "id": "final-report",
        "task_id": "D-0201",
        "agent": "report-writer",
        "depends_on": [
          "java-audit",
          "web-audit",
          "c-audit",
          "python-audit",
          "reverse-audit"
        ],
        "artifact": "artifacts/direct/final-report.md",
        "inputs": [
          "shared/repository-inventory.json",
          "shared/modules.json",
          "artifacts/direct/01-recon.md",
          "artifacts/direct/recon.json",
          "artifacts/direct/02-plan.md",
          "artifacts/direct/domain-plan.json",
          "artifacts/direct/domains/java.md",
          "artifacts/direct/domains/web.md",
          "artifacts/direct/domains/c.md",
          "artifacts/direct/domains/python.md",
          "artifacts/direct/domains/reverse.md",
          "outbox/D-0101.result.json",
          "outbox/D-0102.result.json",
          "outbox/D-0103.result.json",
          "outbox/D-0104.result.json",
          "outbox/D-0105.result.json"
        ],
        "required_sections": [
          "Executive Summary",
          "Scope and Method",
          "Repository and Attack Surface",
          "Planning Decisions",
          "Domain Coverage",
          "Validated Findings",
          "Attack Chains and Correlations",
          "Skipped Domains and Limitations",
          "Remediation Priorities",
          "Evidence Index"
        ],
        "objective": "Integrate the complete direct workflow into one evidence-linked final report."
      }
    ]
  }
}
